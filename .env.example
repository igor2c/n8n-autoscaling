# ==============================================================================
# n8n-autoscaling Stack — Environment Configuration
# ==============================================================================

# Deployment
#  https://docs.n8n.io/hosting/configuration/environment-variables/deployment/
# -----------------
# n8n Docker image version
N8N_VERSION=2.10.3
NODE_ENV=production
COMPOSE_PROJECT_NAME=n8n-autoscaling
COMPOSE_FILE_PATH=/app/docker-compose.yml
# The protocol used to reach n8n (enum: http, https; default=http)
N8N_PROTOCOL=https
# Host name n8n runs on (default=localhost)
N8N_HOST=n8n.domain.com  # Change this
# Public URL where users can access the editor. Also used for emails sent from n8n.
N8N_EDITOR_BASE_URL=https://n8n.domain.com  # Change this
# Provide a custom key used to encrypt credentials in the n8n database (32 characters).
N8N_ENCRYPTION_KEY=YOURKEY  # Change this — generate your own 32-char key
# JWT secret for user management authentication
N8N_USER_MANAGEMENT_JWT_SECRET=YOURKEY  # Change this to a strong password
# When enabled, n8n sends notifications of new versions and security updates (default=true)
N8N_VERSION_NOTIFICATIONS_ENABLED=true
# Whether to share selected, anonymous telemetry with n8n (default=true)
N8N_DIAGNOSTICS_ENABLED=false
# Whether to  automatically attempt to reinstall any missing packages (default=false)
N8N_REINSTALL_MISSING_PACKAGES=true
# Base directory for n8n user data inside the container
N8N_USER_FOLDER=/n8n/main
# Whether the n8n session cookie requires HTTPS (default=true)
N8N_SECURE_COOKIE=true
# Whether to give only the owner read and write access to the settings file. (default=false)
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=false
# Whether to block access to environment variables from within n8n nodes (default=false)
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
# Max size in bytes for data tables (default=1048576000 = ~1 GB)
N8N_DATA_TABLES_MAX_SIZE_BYTES=1048576000


# Timezone
#  https://docs.n8n.io/hosting/configuration/environment-variables/timezone-localization/
#  https://docs.n8n.io/hosting/installation/docker/#setting-timezone
# -----------------
# The n8n instance timezone. Important for schedule nodes (such as Cron).
GENERIC_TIMEZONE=America/Sao_Paulo
# The system timezone, which controls what some scripts and commands like `date` return
TZ=America/Sao_Paulo


# Webhook
#  https://docs.n8n.io/hosting/configuration/environment-variables/endpoints/
#  https://docs.n8n.io/hosting/configuration/configuration-examples/webhook-url/
# -----------------
# Webhook hostname (used internally by the stack for routing)
N8N_WEBHOOK=webhook.domain.com  # Change this
# Used to manually provide the Webhook URL when running n8n behind a reverse proxy
N8N_WEBHOOK_URL=https://webhook.domain.com  # Change this
WEBHOOK_URL=https://webhook.domain.com  # Change this
# Disable webhook processing in the main process (offload to workers)
N8N_DISABLE_PRODUCTION_MAIN_PROCESS=true


# Queue Mode
#  https://docs.n8n.io/hosting/scaling/queue-mode/
#  https://docs.n8n.io/hosting/configuration/environment-variables/queue-mode/
# -----------------
# Whether executions should run directly or using queue (enum: regular, queue)
EXECUTIONS_MODE=queue
# Whether manual test executions are offloaded to workers (default=false; true recommended for production)
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true
# Service name used to discover worker containers (used by the autoscaler)
N8N_WORKER_SERVICE_NAME=n8n-worker
N8N_WORKER_RUNNER_SERVICE_NAME=n8n-worker-runner
# Redis queue-level graceful shutdown timeout in seconds
N8N_QUEUE_BULL_GRACEFULSHUTDOWNTIMEOUT=600
# n8n process-level graceful shutdown timeout in seconds
N8N_GRACEFUL_SHUTDOWN_TIMEOUT=600


# Saved Data and Data Pruning
#  https://docs.n8n.io/hosting/scaling/execution-data/
#  https://docs.n8n.io/hosting/configuration/environment-variables/executions/
# -----------------
# Whether n8n saves execution data on success (enum: all, none; default=all)
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
# Whether n8n saves execution data on error (enum: all, none; default=all)
EXECUTIONS_DATA_SAVE_ON_ERROR=all
# Whether to save progress for each node executed (default=false)
EXECUTIONS_DATA_SAVE_ON_PROGRESS=false
# Whether to delete data of past executions on a rolling basis (default=true)
EXECUTIONS_DATA_PRUNE=true
# The execution age (in hours) before it's deleted (default=336; 336 = 14 days)
EXECUTIONS_DATA_MAX_AGE=336
# Maximum number of executions to keep in the database. 0 = no limit (default=10000)
EXECUTIONS_DATA_PRUNE_MAX_COUNT=50000
# Hours buffer before hard-deleting pruned data
EXECUTIONS_DATA_HARD_DELETE_BUFFER=1


# Task Runners
#  https://docs.n8n.io/hosting/configuration/task-runners/
#  https://docs.n8n.io/hosting/configuration/environment-variables/task-runners/
# -----------------
# Task runners are separate containers in n8n 2.0.
# Each worker gets its own task runner sidecar (scaled 1:1 by the autoscaler).
# Security settings are configured in n8n-task-runners.json.
# Whether to disable all security measures in the task runner. Discouraged for production. (default=false)
N8N_RUNNERS_INSECURE_MODE=false
# Set to true to allow modules like puppeteer at the cost of relaxing security (default=false)
N8N_RUNNERS_ALLOW_PROTOTYPE_MUTATION=false
# Shared auth token between n8n and its task runner sidecars
N8N_RUNNERS_AUTH_TOKEN=YOURPASSWORD  # Change this to a strong password
# Max concurrent tasks per runner (default=5)
N8N_RUNNERS_MAX_CONCURRENCY=5
# Seconds of idle time before a runner shuts itself down (default=15)
N8N_RUNNERS_AUTO_SHUTDOWN_TIMEOUT=15


# External Packages and Community Nodes
#  https://docs.n8n.io/hosting/configuration/environment-variables/executions/#code-node
#  https://docs.n8n.io/integrations/community-nodes/
# -----------------
# Packages allowed in n8n Code nodes (must also be installed in Dockerfile.runner)
NODE_FUNCTION_ALLOW_EXTERNAL=ajv,ajv-formats,puppeteer-core,puppeteer-extra,puppeteer-extra-plugin-stealth,playwright-core,playwright-extra
# Enable installing community nodes from the n8n UI (default=false)
N8N_COMMUNITY_PACKAGES_ENABLED=true
# Allow community packages to be used as tools in AI/agent nodes (default=false)
N8N_COMMUNITY_PACKAGES_ALLOW_TOOL_USAGE=true


# Redis
#  https://docs.n8n.io/hosting/configuration/environment-variables/queue-mode/
# -----------------
# The Redis host
REDIS_HOST=redis
# The Redis port (default=6379)
REDIS_PORT=6379
# The Redis password
REDIS_PASSWORD=YOURREDISPASSWORD  # Change this to a strong password
# Queue name prefix for Bull MQ
QUEUE_NAME_PREFIX=bull
# Queue name used by n8n for job processing
QUEUE_NAME=jobs
# Redis host for Bull queue (mirrors REDIS_HOST)
QUEUE_BULL_REDIS_HOST=redis
# Whether to enable periodic health checks on the queue (default=false)
QUEUE_HEALTH_CHECK_ACTIVE=true


# Database (PostgreSQL)
#  https://docs.n8n.io/hosting/configuration/environment-variables/database/
#  https://docs.n8n.io/hosting/configuration/supported-databases-settings/
# -----------------
# The database type to use
DB_TYPE=postgresdb
# The PostgreSQL host
POSTGRES_HOST=postgres
# PostgreSQL data directory inside the container
PGDATA=/var/lib/postgresql/data/pgdata

# Admin (superuser) — used for database management and migrations
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=YOURADMINPASSWORD  # Change this to a strong password

# Application (limited-privilege user) — used by n8n at runtime.
# The init-postgres.sh script creates this user with restricted privileges.
# Set POSTGRES_APP_PASSWORD to enable user separation; leave empty to use the admin user directly.
POSTGRES_DB=n8n
POSTGRES_USER=n8n_app
POSTGRES_PASSWORD=YOURAPPPASSWORD  # Change this — must match POSTGRES_APP_PASSWORD
POSTGRES_APP_DB=n8n
POSTGRES_APP_USER=n8n_app
POSTGRES_APP_PASSWORD=YOURAPPPASSWORD  # Change this — must match POSTGRES_PASSWORD


# Cloudflare Tunnel
# -----------------
# Token for Cloudflare Tunnel. Leave empty to disable.
CLOUDFLARE_TUNNEL_TOKEN=YOURTOKEN  # Change this or leave empty


# Docker Socket (Optional — for rootless Docker)
# -----------------
# Default: /var/run/docker.sock (standard Docker)
# For rootless Docker, set to: /run/user/<UID>/docker.sock (find your UID with: id -u)
#DOCKER_SOCK=/run/user/1000/docker.sock


# Tailscale (Optional)
# -----------------
# Your Tailscale IP (find with: tailscale ip -4).
# Binds n8n, postgres, and redis ports to your Tailscale network for secure private access.
# When empty, all ports default to 127.0.0.1 (localhost only).
TAILSCALE_IP=TAILSCALEIP  # Change this or leave empty


# Log Rotation (Optional)
# -----------------
# Configure Docker log rotation for all services
#LOG_DRIVER=json-file
#LOG_MAX_SIZE=10m
#LOG_MAX_FILE=3


# Backup (Optional)
#  To enable, uncomment the following line (or add "backup" to COMPOSE_PROFILES)
# -----------------
#COMPOSE_PROFILES=backup
# Cron schedule for automated backups (default: daily at 2 AM)
BACKUP_SCHEDULE=0 2 * * *
# Number of days to retain old backups on remote storage
BACKUP_RETENTION_DAYS=30
# GPG passphrase for encrypting backups (leave empty to disable encryption)
BACKUP_ENCRYPTION_KEY=
# Comma-separated rclone remote destinations (e.g., "r2:my-bucket/n8n,s3:backup-bucket/n8n")
# Configure remotes in backup/rclone.conf (see backup/rclone.conf.example)
BACKUP_RCLONE_DESTINATIONS=
# Run a backup immediately on container start (useful for testing)
BACKUP_RUN_ON_START=false
# Delete local backup files after successful remote upload (set to true to save disk space)
BACKUP_DELETE_LOCAL_AFTER_UPLOAD=false

# Backup — Email notifications (all optional — leave empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=
# Webhook URL for backup notifications (posts JSON payload on success/failure)
BACKUP_WEBHOOK_URL=


# Autoscaling
# -----------------
# Logging level for autoscaler and monitor (enum: DEBUG, INFO, WARNING, ERROR)
# Use DEBUG for detailed diagnostics (queue polling, container counts, cooldown status)
# Use INFO for production (only logs scaling actions, queue activity, errors)
LOG_LEVEL=INFO
# Number of waiting jobs above which the autoscaler adds workers
SCALE_UP_QUEUE_THRESHOLD=5
# Number of waiting jobs below which the autoscaler removes workers
SCALE_DOWN_QUEUE_THRESHOLD=1
# How often the autoscaler checks the queue to decide whether to scale
POLLING_INTERVAL_SECONDS=10
# Minimum seconds between consecutive scaling actions
COOLDOWN_PERIOD_SECONDS=10
# How often the redis-monitor logs queue stats (observability only — no scaling logic)
POLL_INTERVAL_SECONDS=10


# Performance Tuning
#  Adjust these based on your server resources and workload.
#  https://docs.n8n.io/hosting/scaling/queue-mode/#configuring-worker-concurrency
# -----------------
# Number of webhook processor replicas
WEBHOOK_REPLICAS=2
# Minimum number of worker replicas (autoscaler won't scale below this)
MIN_REPLICAS=2
# Maximum number of worker replicas (autoscaler won't scale above this)
MAX_REPLICAS=5
# Max concurrent workflow executions per worker (lower if each workflow is CPU-heavy)
N8N_CONCURRENCY_PRODUCTION_LIMIT=20
# Node.js heap size in MB for n8n processes
NODE_OPTIONS=--max-old-space-size=1536
# PostgreSQL shared buffer pool size
POSTGRES_SHARED_BUFFERS=1GB
# PostgreSQL per-operation memory for sorts, joins, etc.
POSTGRES_WORK_MEM=16MB
# PostgreSQL planner estimate of total OS cache available
POSTGRES_EFFECTIVE_CACHE_SIZE=6GB
# Redis maximum memory limit (0 = no limit)
REDIS_MAXMEMORY=256mb
# Redis eviction policy when maxmemory is reached (default=noeviction — safer, errors on writes)
#  https://redis.io/docs/latest/develop/reference/eviction/
REDIS_MAXMEMORY_POLICY=noeviction

# --- Presets (adjust above to match your server) ---

## Preset: 4 GB RAM
# WEBHOOK_REPLICAS=1
# MIN_REPLICAS=1
# MAX_REPLICAS=2
# N8N_CONCURRENCY_PRODUCTION_LIMIT=5
# NODE_OPTIONS=--max-old-space-size=512
# POSTGRES_SHARED_BUFFERS=256MB
# POSTGRES_WORK_MEM=4MB
# POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
# REDIS_MAXMEMORY=64mb
# REDIS_MAXMEMORY_POLICY=noeviction

## Preset: 8 GB RAM
# WEBHOOK_REPLICAS=1
# MIN_REPLICAS=1
# MAX_REPLICAS=3
# N8N_CONCURRENCY_PRODUCTION_LIMIT=10
# NODE_OPTIONS=--max-old-space-size=768
# POSTGRES_SHARED_BUFFERS=512MB
# POSTGRES_WORK_MEM=8MB
# POSTGRES_EFFECTIVE_CACHE_SIZE=3GB
# REDIS_MAXMEMORY=128mb
# REDIS_MAXMEMORY_POLICY=noeviction

## Preset: 16 GB RAM
# WEBHOOK_REPLICAS=2
# MIN_REPLICAS=2
# MAX_REPLICAS=5
# N8N_CONCURRENCY_PRODUCTION_LIMIT=20
# NODE_OPTIONS=--max-old-space-size=1536
# POSTGRES_SHARED_BUFFERS=1GB
# POSTGRES_WORK_MEM=16MB
# POSTGRES_EFFECTIVE_CACHE_SIZE=6GB
# REDIS_MAXMEMORY=256mb
# REDIS_MAXMEMORY_POLICY=noeviction
